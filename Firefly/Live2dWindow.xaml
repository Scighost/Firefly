<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="Firefly.Live2dWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:l2d="using:Live2DCSharpSDK.WinUI"
        xmlns:local="using:Firefly"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Live2dWindow"
        mc:Ignorable="d">

    <Grid>
        <Grid.ContextFlyout>
            <MenuFlyout x:Name="GridMenuFlyout" Placement="BottomEdgeAlignedLeft">
                <MenuFlyoutItem x:Name="MenuFlyoutItem_BorderlessWindow"
                                Click="MenuFlyoutItem_BorderlessWindow_Click"
                                Text="无边框 + 置顶">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE78B;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="MenuFlyoutItem_RandomMotion"
                                Click="MenuFlyoutItem_RandomMotion_Click"
                                Text="随机表情">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE76E;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="MenuFlyoutItem_CloseWindow"
                                Click="MenuFlyoutItem_CloseWindow_Click"
                                Text="关闭">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE711;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>
        </Grid.ContextFlyout>

        <l2d:Live2DSwapChainPanel x:Name="live2dPanel" />


        <Border x:Name="Border_DragArea"
                Height="48"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Background="{ThemeResource ControlOnImageFillColorDefaultBrush}">
            <FontIcon VerticalAlignment="Center"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                      Glyph="&#xE7C2;" />
        </Border>

    </Grid>
</Window>
