<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="Firefly.TrayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:hn="using:H.NotifyIcon"
        xmlns:local="using:Firefly"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="TrayWindow"
        mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <hn:TaskbarIcon x:Name="trayIcon"
                        LeftClickCommand="{x:Bind ShowMainWindowCommand}"
                        NoLeftClickDelay="True"
                        RightClickCommand="{x:Bind ShowCommand}"
                        ToolTipText="Firefly" />

        <StackPanel Padding="6,8,6,8">

            <Button Height="36"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Command="{x:Bind ShowMainWindowCommand}"
                    Style="{ThemeResource DateTimePickerFlyoutButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon HorizontalAlignment="Center"
                              FontSize="16"
                              Glyph="&#xE80F;" />
                    <TextBlock VerticalAlignment="Center" Text="主页" />
                </StackPanel>
            </Button>
            <Button Height="36"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Command="{x:Bind ExitAppCommand}"
                    Style="{ThemeResource DateTimePickerFlyoutButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon HorizontalAlignment="Center"
                              FontSize="16"
                              Glyph="&#xE7E8;" />
                    <TextBlock VerticalAlignment="Center" Text="退出" />
                </StackPanel>
            </Button>

        </StackPanel>

    </Grid>

</Window>
