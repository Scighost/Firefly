<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="Firefly.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:l2d="using:Live2DCSharpSDK.WinUI"
        xmlns:loc="using:Firefly.Localization"
        xmlns:local="using:Firefly"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Firefly"
        x:DefaultBindMode="OneWay"
        mc:Ignorable="d">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid Loaded="Grid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>


        <l2d:Live2DSwapChainPanel x:Name="live2dPanel" Grid.RowSpan="2" />


        <StackPanel Margin="16,0,0,0"
                    Orientation="Horizontal"
                    Spacing="4">
            <TextBlock VerticalAlignment="Center"
                       FontSize="14"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Firefly" />
            <TextBlock VerticalAlignment="Center"
                       FontSize="14"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="·" />
            <TextBlock VerticalAlignment="Center"
                       FontSize="14"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind AppVersion}" />
        </StackPanel>



        <StackPanel Grid.Row="1"
                    Margin="0,8,12,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    Spacing="8">
            <Button x:Name="Button_PlayPause"
                    Width="28"
                    Height="28"
                    Padding="0"
                    Command="{x:Bind PlayPauseCommand}"
                    Style="{ThemeResource DateTimePickerFlyoutButtonStyle}"
                    ToolTipService.ToolTip="{x:Bind loc:Lang.PlayPause}">
                <FontIcon x:Name="FontIcon_PlayPause"
                          FontSize="18"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          Glyph="&#xE769;" />
            </Button>
            <Button x:Name="Button_Motion"
                    Width="28"
                    Height="28"
                    Padding="0"
                    Command="{x:Bind StartRandomMotionCommand}"
                    Style="{ThemeResource DateTimePickerFlyoutButtonStyle}"
                    ToolTipService.ToolTip="{x:Bind loc:Lang.RandomEmotion}">
                <FontIcon FontSize="18"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          Glyph="&#xE76E;" />
            </Button>
        </StackPanel>



        <Grid Grid.Row="1"
              Grid.Column="1"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1,1,0,0"
              CornerRadius="8,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="Button_NewLiev2dWindow"
                    Height="32"
                    Margin="4"
                    HorizontalAlignment="Stretch"
                    BorderThickness="0"
                    Command="{x:Bind NewLive2dWindowCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Margin="0,0,0,-2"
                              FontSize="18"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              Glyph="&#xE8A7;" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind loc:Lang.NewLive2DWindow}" />
                </StackPanel>
            </Button>

            <TeachingTip x:Name="TeachingTip_NewLive2dWindow"
                         Title="{x:Bind loc:Lang.ClickToNewLive2DWindow}"
                         CloseButtonContent="{x:Bind loc:Lang.DoNotShowAgain}"
                         Closed="TeachingTip_NewLive2dWindow_Closed"
                         Subtitle="{x:Bind loc:Lang.RightClickInTheLive2DWindowToOpenTheMenu}"
                         Target="{x:Bind Button_NewLiev2dWindow}" />

            <Button Grid.Column="2"
                    Width="32"
                    Height="32"
                    Margin="4"
                    Padding="0"
                    BorderThickness="0"
                    Command="{x:Bind ShowInfoCommand}">
                <Grid>
                    <FontIcon FontSize="18"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              Glyph="&#xE946;" />
                    <InfoBadge x:Name="InfoBadge_InfoDialog"
                               Width="8"
                               Height="8"
                               Margin="0,-6,-6,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top"
                               Background="{ThemeResource SystemFillColorCriticalBrush}"
                               Visibility="{x:Bind HasNewRelease}" />
                </Grid>
            </Button>


            <ListView Grid.Row="1"
                      Grid.ColumnSpan="3"
                      ItemsSource="{x:Bind Live2dWindows}"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:Live2DWindowInfo" x:DefaultBindMode="OneWay">
                        <Grid>
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="16"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind Name}" />
                            <Button Width="28"
                                    Height="28"
                                    Margin="0,0,40,0"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    Command="{x:Bind ChangeVisibleCommand}"
                                    Style="{ThemeResource DateTimePickerFlyoutButtonStyle}">
                                <Grid>
                                    <FontIcon FontSize="16"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              Glyph="&#xE890;"
                                              Visibility="{x:Bind IsVisible}" />
                                    <FontIcon FontSize="16"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              Glyph="&#xED1A;"
                                              Visibility="{x:Bind IsNotVisible}" />
                                </Grid>
                            </Button>
                            <Button Width="28"
                                    Height="28"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    Command="{x:Bind CloseWindowCommand}"
                                    Style="{ThemeResource DateTimePickerFlyoutButtonStyle}">
                                <FontIcon FontSize="16"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          Glyph="&#xE711;" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>


        </Grid>


    </Grid>
</Window>
