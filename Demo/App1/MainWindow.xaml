<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="App1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:l2d="using:Live2DCSharpSDK.WinUI"
        xmlns:local="using:App1"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="App1"
        mc:Ignorable="d">

    <Grid Background="Transparent"
          PointerEntered="Grid_PointerEntered"
          PointerExited="Grid_PointerExited">
        <Grid.ContextFlyout>
            <MenuFlyout Placement="BottomEdgeAlignedLeft">
                <MenuFlyoutItem x:Name="MenuFlyoutItem_LoadModel"
                                Click="MenuFlyoutItem_LoadModel_Click"
                                Text="加载模型" />
                <MenuFlyoutItem x:Name="MenuFlyoutItem_BorderlessWindow"
                                Click="MenuFlyoutItem_BorderlessWindow_Click"
                                Text="无边框" />
                <MenuFlyoutItem x:Name="MenuFlyoutItem_CloseWindow"
                                Click="MenuFlyoutItem_CloseWindow_Click"
                                Text="关闭" />
            </MenuFlyout>
        </Grid.ContextFlyout>

        <l2d:Live2DSwapChainPanel x:Name="live2d" />


        <Border x:Name="Border_DragArea"
                Height="48"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Background="{ThemeResource ControlOnImageFillColorDefaultBrush}"
                Opacity="0.8">
            <FontIcon VerticalAlignment="Center" Glyph="&#xE7C2;" />
        </Border>

        <Button x:Name="Button_Menu"
                Width="36"
                Height="36"
                Margin="8"
                Padding="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Opacity="0">
            <FontIcon FontSize="16" Glyph="&#xE700;" />
            <Button.Flyout>
                <MenuFlyout Placement="BottomEdgeAlignedLeft">
                    <MenuFlyoutItem Click="MenuFlyoutItem_LoadModel_Click" Text="加载模型" />
                    <MenuFlyoutItem Click="MenuFlyoutItem_BorderlessWindow_Click" Text="无边框窗口" />
                    <MenuFlyoutItem IsEnabled="False" Text="鼠标右键打开菜单" />
                </MenuFlyout>
            </Button.Flyout>
            <Button.OpacityTransition>
                <ScalarTransition />
            </Button.OpacityTransition>
        </Button>

    </Grid>
</Window>
